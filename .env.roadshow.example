COMPOSE_PROJECT_NAME=factorplatform_roadshow
FRONTEND_PORT=3000
NEXT_PUBLIC_API_KEY=ROADSHOW_ADMIN_KEY
NEXT_PUBLIC_ALLOW_MOCK_FALLBACK=1
NEXT_PUBLIC_DEMO_READONLY=0
NEXT_PUBLIC_MOCK_BACKEND=0
FACTOR_PLATFORM_ALLOW_MOCK_FALLBACK=1
FACTOR_PLATFORM_DEMO_READONLY=0
FACTOR_PLATFORM_MOCK_BACKEND=0
FACTOR_PLATFORM_STALE_DATA_BLOCKS=0
FACTOR_PLATFORM_MARKET_DATA_BACKEND=postgres
FACTOR_PLATFORM_HOST_MCQLIB_DATA=./data/portable/mcqlib
FACTOR_PLATFORM_HOST_KAGGLE_DATA=./data/portable/kaggle
# Optional: created by scripts\build_roadshow_db.ps1 and restored automatically by db-restore.
FACTOR_PLATFORM_ROADSHOW_SEED_DUMP=/app/data/db_dumps/roadshow_demo.dump
