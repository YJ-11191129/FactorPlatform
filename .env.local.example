FACTOR_PLATFORM_API_KEYS=LOCAL_ADMIN_KEY:admin,LOCAL_VIEW_KEY:viewer
FACTOR_PLATFORM_REQUIRE_AUTH=1
FACTOR_PLATFORM_API_PORT=8003
DATABASE_URL=postgresql+psycopg://postgres:factorplatform_dev_password@localhost:5432/factor_platform
REDIS_URL=redis://localhost:6379/0
FACTOR_PLATFORM_REQUIRE_DB=1

FACTOR_PLATFORM_PROVIDER_URI=D:\mcQlib\data\qlib_bin\cn_data
FACTOR_PLATFORM_US_PROVIDER_URI=D:\mcQlib\data\qlib_bin\us_data
FACTOR_PLATFORM_AI_BACKTEST_DATA_SOURCE=qlib
FACTOR_PLATFORM_AI_BACKTEST_QLIB_REGION=cn
FACTOR_PLATFORM_WIND_DATA_ROOT=D:\Kaggle\data\wind_data
FACTOR_PLATFORM_PROCESSED_DATA_ROOT=D:\Kaggle\data\processed
FACTOR_PLATFORM_REAL_OHLCV_PATH=D:\Kaggle\data\wind_data\02_daily_stock\stock_daily_ohlcv.parquet
FACTOR_PLATFORM_FINANCIAL_STATEMENT_PATH=D:\Kaggle\data\processed\financial_statement.parquet
FACTOR_PLATFORM_DATA_MAINTENANCE_DIR=D:\FactorPlatform\data\exports\data_maintenance
# Optional: point this to your own Wind/qlib downloader. It is only executed when explicitly requested.
# FACTOR_PLATFORM_DATA_UPDATE_COMMAND=

# Mock/demo controls. Keep disabled for real backend validation.
NEXT_PUBLIC_MOCK_BACKEND=0
NEXT_PUBLIC_ALLOW_MOCK_FALLBACK=0
FACTOR_PLATFORM_MOCK_BACKEND=0
FACTOR_PLATFORM_ALLOW_MOCK_FALLBACK=0

LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_deepseek_key
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2000

# Optional local OpenAI-compatible model endpoint, such as Ollama or LM Studio.
# Set LLM_PROVIDER=local to prefer this provider for AI Strategy Builder.
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_MODEL=qwen3:14b
LOCAL_LLM_API_KEY=
LOCAL_LLM_TIMEOUT_SECONDS=60
